# Copier ce fichier en `.env` et renseigner les vraies valeurs.
NODE_ENV=development
PORT=4000

# Connexion PostgreSQL (PostgreSQL 18 local). Remplacer MOT_DE_PASSE.
DATABASE_URL="postgresql://postgres:MOT_DE_PASSE@localhost:5432/csi_cnam?schema=public"

# Sécurité (BNF1)
JWT_SECRET="a-changer-absolument-en-production"
JWT_EXPIRES_IN="2h"
MAX_LOGIN_ATTEMPTS=5
# Code d'habilitation pour l'inscription d'un agent assureur (BF1)
AGENT_REGISTRATION_CODE="CNAM-AGENT-2024"
# Clé de chiffrement des données sensibles (coordonnées bancaires — BNF1)
ENCRYPTION_KEY="dev-encryption-key-change-me-please"
# Chemin de pg_dump si absent du PATH (sauvegardes — BNF3)
# PG_DUMP_PATH="C:\\Program Files\\PostgreSQL\\18\\bin\\pg_dump.exe"

# CORS : origine du front Vite
CORS_ORIGIN="http://localhost:5173"
